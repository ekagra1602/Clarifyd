# Convex deployment URL (set automatically by `npx convex dev`)
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Claude API key for AI features (get from https://console.anthropic.com/settings/keys)
CLAUDE_API_KEY=your-claude-api-key
# Optional model override (defaults to Sonnet 4)
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Token Company API for prompt compression (reduces token costs)
TOKEN_COMPANY_API_KEY=your-token-company-api-key
# Optional: set to "false" to disable compression globally (defaults to "true")
# COMPRESSION_ENABLED=true

# AssemblyAI API key for real-time transcription (get from https://www.assemblyai.com/dashboard)
ASSEMBLYAI_API_KEY=your-assemblyai-api-key
