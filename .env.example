# Convex deployment URL (set automatically by `npx convex dev`)
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Convex "site" URL for HTTP endpoints (used by external ingestion scripts)
# You can usually derive it by replacing `.convex.cloud` with `.convex.site`.
VITE_CONVEX_SITE_URL=https://your-deployment.convex.site

# Shared secret for POST /transcription (keep this private)
TRANSCRIPTION_SECRET=your-strong-random-secret

# Claude API key for AI features (get from https://console.anthropic.com/settings/keys)
CLAUDE_API_KEY=your-claude-api-key
# Optional model override (defaults to Sonnet 4)
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Token Company API for prompt compression (reduces token costs)
TOKEN_COMPANY_API_KEY=your-token-company-api-key
# Optional: set to "false" to disable compression globally (defaults to "true")
# COMPRESSION_ENABLED=true

# AssemblyAI API key for real-time transcription (get from https://www.assemblyai.com/dashboard)
ASSEMBLYAI_API_KEY=your-assemblyai-api-key

# Veo video generation (Google AI Studio key + optional model override)
VEO_API_KEY=your-veo-api-key
# VEO_MODEL=veo-3.1-fast-generate-preview
# Zoom Server-to-Server OAuth (for post-hoc transcript import)
# Create an S2S OAuth app in Zoom Marketplace, then set:
ZOOM_ACCOUNT_ID=your-zoom-account-id
ZOOM_CLIENT_ID=your-zoom-client-id
ZOOM_CLIENT_SECRET=your-zoom-client-secret

# Gemini API key (used by scripts/ears/local_loopback_gemini.py)
GEMINI_API_KEY=your-gemini-api-key
